# Shared household password. When set, /login is required for all pages/APIs.
HOUSEHOLD_PASSWORD=

# Required when HOUSEHOLD_PASSWORD is set (min 32 characters).
AUTH_SECRET=

# Cloudflare D1 is used in production (Workers). Local `next dev` / tests fall
# back to data/*.json via AtomicJsonStore when MEALS_DB is unavailable.
# DATABASE_URL=  # unused; Postgres adapter not wired

# Instacart Developer Platform (currently closed to new applicants).
# Leave disabled to use export + Instacart search links.
INSTACART_ENABLED=false
# INSTACART_API_KEY=
